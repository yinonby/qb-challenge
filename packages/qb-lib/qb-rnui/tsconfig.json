{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "lib": ["ESNext", "DOM"],
    "allowJs": true,
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "types": ["node", "jest"],
    "paths": {
      "@qb-rnui/*": ["src/*"],
    }
  },
  "exclude": ["node_modules", "babel.config.js", "metro.config.js"],
  "include": ["**/*.ts", "**/*.tsx"]
}
