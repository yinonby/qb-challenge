{
  "name": "@qb/utils",
  "version": "1.0.0",
  "description": "",
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "index.ts",
  "scripts": {
    "build": "echo nothing to do",
    "test": "npm run pretty && npm run build && npm run tsc && npm run lint && npm run cover:unit",
    "pretty": "npm run pretty:package",
    "pretty:package": "prettier --write package.json",
    "tsc": "npx tsc",
    "lint": "npm run lint:eslint && npm run lint:cycles",
    "lint:eslint": "eslint -c ./.eslint.config.mjs ./src",
    "lint:fix": "npm run lint:eslint -- --fix",
    "lint:cycles": "madge --circular --extensions ts,tsx,js .",
    "test:unit": "cross-env NODE_ENV=test LOG_LEVEL=SILENT vitest",
    "ut": "npm run test:unit --",
    "test:verbose": "cross-env NODE_ENV=test LOG_LEVEL=VERBOSE vitest",
    "cover:unit": "npm run test:unit -- run --coverage"
  },
  "devDependencies": {
    "@qb/lint": "*",
    "@qb/ts-deps": "*",
    "@qb/vitest": "*",
    "@types/node": "^25.0.3",
    "cross-env": "^7.0.3"
  }
}
