{
  "name": "qb-challenge",
  "version": "1.0.0",
  "description": "A beautiful products dashboard",
  "homepage": "https://github.com/yinonby/qb-challenge#readme",
  "bugs": {
    "url": "https://github.com/yinonby/qb-challenge/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yinonby/qb-challenge.git"
  },
  "license": "ISC",
  "author": "Yinon",
  "type": "module",
  "scripts": {
    "test": "npm run husky:verify:setup && npm run test:all",
    "test:all": "./scripts/python/src/test/test-all.py",
    "cover:report": "npm run cover:report:produce && npm run cover:report:open",
    "cover:report:produce": "npm run cover:report:produce:npm",
    "cover:report:produce:npm": "./scripts/python/src/coverage/npm/produce-coverage-report.py",
    "cover:report:open": "npm run cover:report:open:npm",
    "cover:report:open:npm": "./scripts/python/src/coverage/npm/open-coverage-report.py",
    "clean": "npm run clean:modules && npm run clean:lock",
    "clean:modules": "for x in $(find . -name node_modules); do rm -rf $x; done",
    "clean:lock": "rm package-lock.json",
    "husky:verify:setup": "npm run husky:verify:installed && npm run husky:verify:configured",
    "husky:verify:installed": "[ $(git config --get core.hooksPath) = \".husky/_\" ]",
    "husky:verify:configured": "[ -f \".husky/pre-push\" ]",
    "pre-push": "npm run pre-push:no-local-changes && npm test",
    "pre-push:no-local-changes": "[ ! -n \"$(git status --porcelain)\" ]",
    "prepare": "husky"
  },
  "workspaces": [
    "packages/qb-dev-lib/*",
    "packages/qb-lib/*",
    "packages/qb-app/*",
    "apps/*"
  ],
  "devDependencies": {
    "husky": "^9.1.7",
    "nyc": "^17.1.0"
  }
}
